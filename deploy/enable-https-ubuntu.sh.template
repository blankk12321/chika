#!/usr/bin/env bash
set -euo pipefail

DOMAIN="{{DOMAIN}}"
EMAIL="{{CERTBOT_EMAIL}}"

if [ "$(id -u)" -ne 0 ]; then
  echo "Run this script as root."
  exit 1
fi

apt-get update
apt-get install -y certbot python3-certbot-nginx

certbot --nginx \
  --non-interactive \
  --agree-tos \
  --redirect \
  --email "$EMAIL" \
  -d "$DOMAIN" \
  -d "www.$DOMAIN"

systemctl reload nginx
certbot renew --dry-run

echo "HTTPS is enabled for $DOMAIN and www.$DOMAIN."
